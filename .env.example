# ─── Site Configuration ──────────────────────────────────────────────────────
SITE_BASE_URL=https://latabledessavoirs.fr

# ─── Pre-obtained Site JWT (optional shortcut) ───────────────────────────────
# Paste the full ltds-auth value from the browser's localStorage here to skip
# the Playwright login step entirely. Leave empty to use Playwright.
# Get it from DevTools: Application → Local Storage → select latabledessavoirs.fr → ltds-auth
# Value is a JSON string: {"token": "eyJ...", "expiresAt": 1234567890000}
SITE_JWT=

# ─── Output ──────────────────────────────────────────────────────────────────
# Directory where JSON results are saved
OUTPUT_DIR=output
